          {
            "name": "surface-condition",
            "exclusivity": "co-holding",
            "values": [
              "cracked",
              "stained",
              "clean"
            ]
          }
        ],
        "boundary": "the pillar as poured and the site datum network; downstream load-transfer decisions are outside the boundary",
