{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/candidate-topology.schema.json",
  "title": "Frozen candidate pull-request topology observation",
  "type": "object",
  "required": [
    "schema",
    "observed_at_utc",
    "observation_source",
    "timeless_state",
    "merged_base",
    "pull_requests",
    "merge_order",
    "candidate_documents",
    "candidate_pdfs",
    "status_claims"
  ],
  "properties": {
    "schema": {"const": "orthemology-candidate-topology-v1"},
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "observation_source": {"type": "string", "minLength": 1},
    "timeless_state": {"const": false},
    "merged_base": {"$ref": "#/$defs/merged_base"},
    "pull_requests": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"$ref": "#/$defs/pull_request"}
    },
    "merge_order": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"type": "integer"}
    },
    "candidate_documents": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string", "minLength": 1},
        "uniqueItems": true
      }
    },
    "candidate_pdfs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "status_claims": {"$ref": "#/$defs/status_claims"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "decision_id": {"type": "string", "pattern": "^[0-9]{4}$"},
    "merged_base": {
      "type": "object",
      "required": ["ref", "sha", "revision", "merged_decisions", "protection"],
      "properties": {
        "ref": {"const": "main"},
        "sha": {"$ref": "#/$defs/sha"},
        "revision": {"type": "string", "minLength": 1},
        "merged_decisions": {"type": "string", "minLength": 1},
        "protection": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["layer", "model", "statement"],
      "properties": {
        "layer": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "pull_request": {
      "type": "object",
      "required": [
        "pr",
        "revision",
        "base_branch",
        "base_head_at_observation",
        "head_branch",
        "head_at_observation",
        "state",
        "draft",
        "mergeable_at_observation",
        "checks_at_observation",
        "candidate_decisions",
        "provenance"
      ],
      "properties": {
        "pr": {"type": "integer"},
        "revision": {"type": "string", "minLength": 1},
        "base_branch": {"type": "string", "minLength": 1},
        "base_head_at_observation": {"$ref": "#/$defs/sha"},
        "head_branch": {"type": "string", "minLength": 1},
        "head_at_observation": {"$ref": "#/$defs/sha"},
        "state": {"type": "string", "minLength": 1},
        "draft": {"type": "boolean"},
        "mergeable_at_observation": {"type": "string", "minLength": 1},
        "checks_at_observation": {"type": "string", "minLength": 1},
        "candidate_decisions": {
          "type": "array",
          "items": {"$ref": "#/$defs/decision_id"},
          "uniqueItems": true
        },
        "provenance": {"$ref": "#/$defs/provenance"}
      },
      "additionalProperties": false
    },
    "status_claims": {
      "type": "object",
      "required": ["candidate_status", "merged", "independent_signoff", "ready_for_merge", "evidence", "next_action"],
      "properties": {
        "candidate_status": {"const": "proposed-candidate"},
        "merged": {"type": "boolean"},
        "independent_signoff": {"type": "boolean"},
        "ready_for_merge": {"type": "boolean"},
        "evidence": {
          "type": "object",
          "required": ["merged", "independent_signoff", "ready_for_merge"],
          "properties": {
            "merged": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "independent_signoff": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "ready_for_merge": {"type": "array", "items": {"type": "string", "minLength": 1}}
          },
          "additionalProperties": false
        },
        "next_action": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
