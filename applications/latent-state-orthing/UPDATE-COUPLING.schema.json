{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orthemology-update-coupling-v1",
  "title": "Governed update-coupling schema (R7D, Decision 0033 / Phase I, audit B34)",
  "description": "Schema-validates the four update-level transitions. `transport` is a STRUCTURED, GATED object — not free text — so a silent/universal transport rule fails (probe P7). Every transport requires an explicit argument.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "transitions", "non_claims"],
  "properties": {
    "schema": {"const": "orthemology-update-coupling-v1"},
    "transitions": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["level", "symbol", "trigger", "authority", "input", "version", "transport", "calibration", "catastrophic_forgetting_check", "invalidated", "reopening", "rollback"],
        "properties": {
          "level": {"enum": ["episode-inference", "representation-learning", "repertoire-revision", "analysis-version-change"]},
          "symbol": {"type": "string"},
          "trigger": {"type": "string", "minLength": 1},
          "authority": {"type": "string", "minLength": 1},
          "input": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "transport": {
            "type": "object",
            "additionalProperties": false,
            "required": ["default", "argument_required", "rule"],
            "properties": {
              "default": {"const": "no-transport-without-argument"},
              "argument_required": {"const": true},
              "rule": {"type": "string", "minLength": 1}
            }
          },
          "calibration": {"type": "string", "minLength": 1},
          "catastrophic_forgetting_check": {"type": "string", "minLength": 1},
          "invalidated": {"type": "string", "minLength": 1},
          "reopening": {"type": "string", "minLength": 1},
          "rollback": {"type": "string", "minLength": 1},
          "non_claim": {"type": "string"}
        }
      }
    },
    "non_claims": {"type": "array", "items": {"type": "string"}}
  }
}
