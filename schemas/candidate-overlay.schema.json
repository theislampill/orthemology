{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/candidate-overlay.schema.json",
  "title": "Generated complete candidate-state overlay",
  "type": "object",
  "required": [
    "schema",
    "note",
    "generated_from",
    "label",
    "observed_at_utc",
    "observation_source",
    "timeless_state",
    "merged",
    "merged_base",
    "pr_chain",
    "merge_order",
    "candidate_decisions",
    "candidate_documents",
    "candidate_pdfs",
    "provenance_layers",
    "status_claims",
    "no_merge_status"
  ],
  "properties": {
    "schema": {"const": "orthemology-candidate-overlay-v2"},
    "note": {"type": "string", "minLength": 1},
    "generated_from": {"const": "docs/project-closure/r7e-sol/CANDIDATE-TOPOLOGY-INPUT.yaml"},
    "label": {"type": "string", "minLength": 1},
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "observation_source": {"type": "string", "minLength": 1},
    "timeless_state": {"const": false},
    "merged": {"const": false},
    "merged_base": {"$ref": "#/$defs/merged_base"},
    "pr_chain": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"$ref": "#/$defs/overlay_pr"}
    },
    "merge_order": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"type": "integer"}
    },
    "candidate_decisions": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[0-9]{4}$"},
      "uniqueItems": true
    },
    "candidate_documents": {"type": "object"},
    "candidate_pdfs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "provenance_layers": {
      "type": "object",
      "minProperties": 5,
      "additionalProperties": {"$ref": "#/$defs/provenance"}
    },
    "status_claims": {"$ref": "#/$defs/status_claims"},
    "no_merge_status": {
      "type": "object",
      "required": ["merged", "independent_signoff", "ready_for_merge", "next_action"],
      "properties": {
        "merged": {"const": false},
        "independent_signoff": {"const": false},
        "ready_for_merge": {"const": false},
        "next_action": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "merged_base": {
      "type": "object",
      "required": ["ref", "sha", "revision", "merged_decisions", "protection"],
      "properties": {
        "ref": {"const": "main"},
        "sha": {"$ref": "#/$defs/sha"},
        "revision": {"type": "string", "minLength": 1},
        "merged_decisions": {"type": "string", "minLength": 1},
        "protection": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["layer", "model", "statement"],
      "properties": {
        "layer": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "status_claims": {
      "type": "object",
      "required": ["candidate_status", "merged", "independent_signoff", "ready_for_merge", "evidence", "next_action"],
      "properties": {
        "candidate_status": {"const": "proposed-candidate"},
        "merged": {"type": "boolean"},
        "independent_signoff": {"type": "boolean"},
        "ready_for_merge": {"type": "boolean"},
        "evidence": {
          "type": "object",
          "required": ["merged", "independent_signoff", "ready_for_merge"],
          "properties": {
            "merged": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "independent_signoff": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "ready_for_merge": {"type": "array", "items": {"type": "string", "minLength": 1}}
          },
          "additionalProperties": false
        },
        "next_action": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "overlay_pr": {
      "type": "object",
      "required": [
        "pr",
        "revision",
        "branch",
        "base",
        "base_head_at_observation",
        "head_at_observation",
        "state",
        "draft",
        "mergeable_at_observation",
        "checks_at_observation",
        "candidate_decisions",
        "provenance"
      ],
      "properties": {
        "pr": {"type": "integer"},
        "revision": {"type": "string", "minLength": 1},
        "branch": {"type": "string", "minLength": 1},
        "base": {"type": "string", "minLength": 1},
        "base_head_at_observation": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "head_at_observation": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "state": {"type": "string", "minLength": 1},
        "draft": {"type": "boolean"},
        "mergeable_at_observation": {"type": "string", "minLength": 1},
        "checks_at_observation": {"type": "string", "minLength": 1},
        "candidate_decisions": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[0-9]{4}$"},
          "uniqueItems": true
        },
        "provenance": {"$ref": "#/$defs/provenance"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
