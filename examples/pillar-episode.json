          "four-face level readings",
          "instrument calibration certificate"
        ],
        "action_repertoire": [
          "release-for-load-transfer",
          "hold-for-rework"
        ],
        "loss": "releasing an out-of-tolerance pillar dominates; holding a within-tolerance pillar costs schedule only",
