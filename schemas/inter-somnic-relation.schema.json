{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/inter-somnic-relation.schema.json",
  "title": "Provenance-preserving relation between distinct somnic episodes",
  "type": "object",
  "additionalProperties": false,
  "required": ["inter_somnic_relation_id", "asserting_episode_id", "source_episode_id", "target_episode_id", "source_assessment_ids", "target_assessment_ids", "semantic_relation", "relation_reason", "run_relation", "operator_relation", "information_path", "material_delta_id", "provenance", "asserted_at", "confidence", "claim_status", "reopens_source", "source_episode_state_preserved", "source_assessment_state_preserved", "inherited_properties", "non_claims", "received_at_t2_evidence_ids", "source_t1_evidence_ids", "target_t1_evidence_ids", "independence_claim", "assessment_depth", "auto_requeue", "idempotency_key", "operation_version"],
  "properties": {
    "inter_somnic_relation_id": {"type": "string", "minLength": 1},
    "asserting_episode_id": {"type": "string", "minLength": 1},
    "source_episode_id": {"type": "string", "minLength": 1},
    "target_episode_id": {"type": "string", "minLength": 1},
    "source_assessment_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "target_assessment_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "semantic_relation": {"enum": ["compares-with", "reopens", "reassesses", "corroborates", "contradicts", "evaluates-outcome-of", "transcludes-from", "adapts-from", "collective-synthesizes", "continues-after-abandonment"]},
    "relation_reason": {"type": "string", "minLength": 1},
    "run_relation": {"enum": ["same-run", "cross-run"]},
    "operator_relation": {"enum": ["same-operator", "cross-operator"]},
    "information_path": {"enum": ["none-independent-discovery", "local-historical-lookup", "shared-public-source", "direct-transclusion", "shared-registry", "common-upstream-update", "explicit-coordination"]},
    "material_delta_id": {"type": ["string", "null"], "minLength": 1},
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["source_operator_id", "source_ledger_id", "target_operator_id", "target_ledger_id", "received_artifact_ref", "receipt_time", "redactions", "source_status_result", "local_meta_orthability_assessment_id", "local_disposition"],
      "properties": {
        "source_operator_id": {"type": "string", "minLength": 1},
        "source_ledger_id": {"type": "string", "minLength": 1},
        "target_operator_id": {"type": "string", "minLength": 1},
        "target_ledger_id": {"type": "string", "minLength": 1},
        "received_artifact_ref": {"type": ["string", "null"], "minLength": 1},
        "receipt_time": {"type": ["string", "null"], "format": "date-time"},
        "redactions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "source_status_result": {"enum": ["verified", "qualified", "unverified", "not-applicable"]},
        "local_meta_orthability_assessment_id": {"type": ["string", "null"], "minLength": 1},
        "local_disposition": {"enum": ["comparator-only", "locally-assessable", "held", "rejected", "not-applicable"]}
      }
    },
    "asserted_at": {"type": "string", "format": "date-time"},
    "confidence": {"enum": ["low", "medium", "high", "undetermined"]},
    "claim_status": {"enum": ["asserted", "qualified", "held"]},
    "reopens_source": {"type": "boolean"},
    "source_episode_state_preserved": {"const": true},
    "source_assessment_state_preserved": {"const": true},
    "inherited_properties": {"type": "array", "maxItems": 0},
    "non_claims": {"type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": {"enum": ["does-not-transfer-applicability", "does-not-transfer-closure", "does-not-transfer-confidence", "does-not-transfer-authority", "does-not-transfer-evidence-time"]}},
    "received_at_t2_evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "source_t1_evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "target_t1_evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "independence_claim": {"type": "boolean"},
    "assessment_depth": {"type": ["integer", "null"], "minimum": 1},
    "auto_requeue": {"const": false},
    "idempotency_key": {"type": "string", "minLength": 1},
    "operation_version": {"type": "string", "minLength": 1}
  }
}
