{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/somnus-run.schema.json",
  "title": "Bounded somnus operation run",
  "type": "object",
  "additionalProperties": false,
  "required": ["somnus_run_id", "operation_id", "operation_version", "anchor_subject_ids", "reference_corpus_revision", "historical_comparator_ids", "historical_comparators_reopened", "selection_rule", "governing_versions", "material_delta_ids", "idempotency_key", "started_at", "completed_at", "output_ids", "runtime_status"],
  "properties": {
    "somnus_run_id": {"type": "string", "minLength": 1},
    "operation_id": {"const": "residual_recurrence_assessment"},
    "operation_version": {"type": "string", "minLength": 1},
    "anchor_subject_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "reference_corpus_revision": {"type": "string", "minLength": 1},
    "historical_comparator_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "historical_comparators_reopened": {"type": "boolean"},
    "selection_rule": {"type": "string", "minLength": 1},
    "governing_versions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "material_delta_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "reopens_subject_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "idempotency_key": {"type": "string", "minLength": 1},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "output_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "runtime_status": {"const": "fixture_only_no_runtime"}
  }
}
