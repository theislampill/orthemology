{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/somnus-history-checkpoints.schema.json",
  "title": "Versioned immutable Somnus target-history checkpoint chain",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "chain", "checkpoints"],
  "properties": {
    "schema": {"const": "orthemology-somnus-history-checkpoints-v1"},
    "chain": {
      "type": "object", "additionalProperties": false,
      "required": ["chain_id", "chain_version", "digest_algorithm", "authority_ref", "immutable"],
      "properties": {
        "chain_id": {"type": "string", "minLength": 1},
        "chain_version": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha256-canonical-json-v1"},
        "authority_ref": {"const": "docs/decisions/0035-somnic-orthing-and-activation-contracts.md#history-checkpoint-chain"},
        "immutable": {"const": true}
      }
    },
    "checkpoints": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["checkpoint_id", "subject_id", "captured_through", "event_ids", "predecessor_checkpoint_digest", "checkpoint_digest", "immutable"],
        "properties": {
          "checkpoint_id": {"type": "string", "minLength": 1},
          "subject_id": {"type": "string", "minLength": 1},
          "captured_through": {"type": "string", "format": "date-time"},
          "event_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "predecessor_checkpoint_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "checkpoint_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "immutable": {"const": true}
        }
      }
    }
  }
}
