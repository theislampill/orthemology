{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/orthing-event.schema.json",
  "title": "Append-only orthing checkpoint event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "sequence", "session_id", "episode_id", "occurrence_id", "orthing_id", "event_type", "occurred_at", "actor_id", "capture_mode", "provenance_record_id", "source_revision", "privacy_source_disposition", "governing_versions", "evidence_timing", "append_only"],
  "allOf": [
    {
      "if": {"properties": {"event_type": {"const": "orthability_assessed"}}, "required": ["event_type"]},
      "then": {
        "properties": {
          "claim_attempt_id": {"type": "string", "minLength": 1},
          "orthability_assessment_id": {"type": "string", "minLength": 1}
        }
      }
    }
  ],
  "properties": {
    "event_id": {"type": "string", "minLength": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "session_id": {"type": "string", "minLength": 1},
    "episode_id": {"type": "string", "minLength": 1},
    "occurrence_id": {"type": "string", "minLength": 1},
    "claim_attempt_id": {"type": ["string", "null"], "minLength": 1},
    "orthability_assessment_id": {"type": ["string", "null"], "minLength": 1},
    "orthing_id": {"type": "string", "minLength": 1},
    "event_type": {"enum": ["occurrence_apprehended", "orthability_assessed", "candidate_set_recorded", "route_selected", "placement_committed", "residual_recorded", "orthing_closed", "orthing_abandoned", "orthing_reopened", "somnus_assessment_emitted", "proposal_emitted"]},
    "occurred_at": {"type": "string", "format": "date-time"},
    "actor_id": {"type": "string", "minLength": 1},
    "capture_mode": {"enum": ["live_capture", "retrospective_reconstruction", "bootstrap_provenance", "unknown"]},
    "provenance_record_id": {"type": "string", "minLength": 1},
    "source_case": {"type": "string", "minLength": 1},
    "source_revision": {"type": "string", "minLength": 1},
    "privacy_source_disposition": {
      "type": "object", "additionalProperties": false,
      "required": ["privacy_scope_applied", "source_scope_applied", "minimal_capture_precedes_claiming"],
      "properties": {
        "privacy_scope_applied": {"const": true},
        "source_scope_applied": {"const": true},
        "minimal_capture_precedes_claiming": {"const": true}
      }
    },
    "governing_versions": {
      "type": "object", "additionalProperties": false,
      "required": ["analysis", "activation_contract", "orthability_evaluator", "selector"],
      "properties": {
        "analysis": {"type": "string", "minLength": 1},
        "activation_contract": {"type": "string", "minLength": 1},
        "orthability_evaluator": {"type": "string", "minLength": 1},
        "selector": {"type": "string", "minLength": 1}
      }
    },
    "evidence_timing": {"$ref": "#/$defs/evidence_timing"},
    "append_only": {"const": true},
    "episode_record_ref": {"type": "string", "minLength": 1},
    "claim_ledger_ref": {"type": "string", "minLength": 1},
    "verdict_record_ref": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "id_set": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "evidence_timing": {
      "type": "object", "additionalProperties": false,
      "required": ["observed_at_t1", "used_at_t1", "indexed_unused_at_t1", "discovered_after_t1"],
      "properties": {
        "observed_at_t1": {"$ref": "#/$defs/id_set"},
        "used_at_t1": {"$ref": "#/$defs/id_set"},
        "indexed_unused_at_t1": {"$ref": "#/$defs/id_set"},
        "discovered_after_t1": {"$ref": "#/$defs/id_set"}
      }
    }
  }
}
