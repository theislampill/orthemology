{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/hermes-writeback-adoption-profile.schema.json",
  "title": "Outline-only downstream writeback adoption profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "execution", "runtime owner", "upstream adoption", "claim_status", "source_verification", "predecessor_characterization", "subsumption", "actuator", "record_separation", "proposal_provenance_modes", "temporal_roles", "automatic_proposal", "automatic authorization", "automatic application", "automatic writeback", "non_claims"],
  "properties": {
    "schema": {"const": "orthemology-hermes-writeback-adoption-profile-v1"},
    "status": {"const": "outline-only"},
    "execution": {"const": "not implemented in orthemology"},
    "runtime owner": {"const": "external/downstream"},
    "upstream adoption": {"const": "candidate, not normative dependency"},
    "claim_status": {"type": "object"},
    "source_verification": {"type": "object"},
    "predecessor_characterization": {"type": "string", "minLength": 1},
    "subsumption": {
      "type": "object", "additionalProperties": false,
      "required": ["ordinary_reflective_writeback_question_is_first_class", "ordinary_targets", "governing_targets", "outcomes"],
      "properties": {
        "ordinary_reflective_writeback_question_is_first_class": {"const": true},
        "ordinary_targets": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"enum": ["memory", "user_state", "fact", "skill"]}},
        "governing_targets": {"type": "array", "minItems": 11, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "outcomes": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "actuator": {"type": "object"},
    "record_separation": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "proposal_provenance_modes": {"type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": {"enum": ["legacy_reflective_proposal", "somnus_grounded_proposal"]}},
    "temporal_roles": {"type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "automatic_proposal": {"const": "prohibited"},
    "automatic authorization": {"const": "prohibited"},
    "automatic application": {"const": "prohibited"},
    "automatic writeback": {"const": "prohibited"},
    "non_claims": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
