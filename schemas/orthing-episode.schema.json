{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orthemology/orthing-episode.schema.json",
  "title": "Orthing episode e — the auditable record (core 2.2)",
  "description": "Orthing episode e — the auditable record (core 2.2). R3: observation, evidence (may be empty but must be declared), warrant (nullable, declared), policy, and verdict_record_ref (nullable, declared) are required so that an episode record is auditable rather than skeletal. R4: record_mode is declared explicitly. 'audit-ready' triggers the full conditional contract below; 'minimal' is an honest label for a record that does NOT support audit — it is not a licence to omit the base fields.",
  "type": "object",
  "required": [
    "episode_id",
    "record_mode",
    "occurrence",
    "actor",
    "analysis",
    "time",
    "placement",
    "observation",
    "evidence",
    "warrant",
    "policy",
    "verdict_record_ref"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "record_mode": {
            "const": "audit-ready"
          }
        },
        "required": [
          "record_mode"
        ]
      },
      "then": {
        "required": [
          "actor",
          "time",
          "analysis",
          "occurrence",
          "observation",
          "evidence",
          "claim_ledger_ref",
          "verdict_record_ref"
        ],
        "properties": {
          "actor": {
            "minLength": 1
          },
          "time": {
            "minLength": 1
          },
          "observation": {
            "minLength": 1,
            "minProperties": 1
          },
          "claim_ledger_ref": {
            "type": "string",
            "minLength": 1
          },
          "verdict_record_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "allOf": [
          {
            "anyOf": [
              {
                "properties": {
                  "policy": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "policy"
                ]
              },
              {
                "required": [
                  "policy_inapplicable_reason"
                ]
              }
            ]
          },
          {
            "anyOf": [
              {
                "properties": {
                  "evidence": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              },
              {
                "required": [
                  "evidence_absent_reason"
                ]
              }
            ],
            "description": "an audit-ready episode carries evidence, or states explicitly why none exists"
          },
          {
            "anyOf": [
              {
                "properties": {
                  "placement": {
                    "type": "object",
                    "minProperties": 1
                  }
                },
                "required": [
                  "placement"
                ]
              },
              {
                "properties": {
                  "candidates": {
                    "type": "object",
                    "minProperties": 1
                  }
                },
                "required": [
                  "candidates"
                ]
              }
            ],
            "description": "an audit-ready episode records a placement or a candidate set"
          }
        ],
        "description": "audit-ready contract: a skeletal record cannot claim audit readiness. Every field an auditor must read to re-derive the verdict is present and nonempty."
      }
    },
    {
      "anyOf": [
        {
          "properties": {
            "policy": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "policy"
          ]
        },
        {
          "required": [
            "policy_inapplicable_reason"
          ]
        }
      ],
      "description": "policy is declared, or its inapplicability is declared with a reason"
    }
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "record_mode": {
      "enum": [
        "audit-ready",
        "minimal"
      ],
      "description": "declared audit posture of this record. 'audit-ready': the record claims to carry everything an auditor needs and is held to the full conditional contract. 'minimal': the record is an honest partial trace and makes no audit claim."
    },
    "occurrence": {
      "$ref": "orthemma.schema.json"
    },
    "observation": {
      "type": [
        "string",
        "object"
      ],
      "minLength": 1,
      "minProperties": 1,
      "description": "x = Omega_e(m); what the episode actually saw"
    },
    "evidence": {
      "type": "array",
      "description": "H — ordered typed evidence; each item typed, scoped, provenanced, expiring",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "channel",
          "property_class",
          "scope",
          "provenance",
          "validity"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "type": "string",
            "minLength": 1
          },
          "property_class": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1,
            "description": "claims/versions/levels the item can bear on at all"
          },
          "provenance": {
            "type": "string",
            "minLength": 1,
            "description": "which process, from which (kappa,v)"
          },
          "validity": {
            "type": "string",
            "minLength": 1,
            "description": "currency conditions / expiry"
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "evidence_absent_reason": {
      "type": "string",
      "minLength": 1,
      "description": "explicit reason an audit-ready episode carries no evidence item"
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "description": "alpha — populated even for mechanical executors"
    },
    "warrant": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "w — who/what authorized acting, with scope; distinct from evidence and from executor identity"
    },
    "analysis": {
      "type": "object",
      "required": [
        "analysis_id",
        "version"
      ],
      "properties": {
        "analysis_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "task": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "time": {
      "type": "string",
      "minLength": 1,
      "description": "t — interval"
    },
    "governing_configuration": {
      "type": "object",
      "properties": {
        "mu_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": [
              "mu_id",
              "mu_version"
            ],
            "properties": {
              "mu_id": {
                "type": "string",
                "minLength": 1
              },
              "mu_version": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "precedence": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 2,
            "maxItems": 2
          },
          "description": "strict partial order pairs [outranks, outranked]"
        }
      },
      "additionalProperties": false
    },
    "meta_tokens": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "metaorthemma.schema.json"
      },
      "description": "MetaTok(e); empty => GOV_TOKEN_ADEQUATE not in ReqPath (zero-burden rule)"
    },
    "policy": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "pi"
    },
    "policy_inapplicable_reason": {
      "type": "string",
      "minLength": 1,
      "description": "explicit reason no policy governs this episode"
    },
    "candidates": {
      "type": "object",
      "description": "typed candidate families C-vector",
      "properties": {
        "identity": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "profile": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "minProperties": 1
          },
          "description": "C-hat subset of Pi_A: a SET whose each member is a COMPLETE profile. It is never one vague partial profile — collapsing the set into a single partial profile object is a type error (B1)."
        },
        "cause": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "route": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "warrant_state": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "authorized",
              "established",
              "both",
              "neither"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "placement": {
      "type": "object",
      "minProperties": 1,
      "description": "p-hat in Pi_A^partial — axis->value(s); open axes carry their admissible sets"
    },
    "route": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "evidence_status": {
      "type": "object",
      "description": "estatus_e per claim",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "enum": [
          "validated",
          "provisional",
          "stale",
          "absent"
        ]
      }
    },
    "claim_ledger_ref": {
      "type": "string",
      "minLength": 1,
      "description": "claim-ledger.schema.json instance (Q_e + delta_e)"
    },
    "handoffs_in": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "handoff.schema.json"
      }
    },
    "handoffs_out": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "handoff.schema.json"
      }
    },
    "action": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "successors": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "identity_key",
          "version",
          "action_label"
        ],
        "properties": {
          "identity_key": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "action_label": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "trace_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "bounded ordered trace where governance requires one; granularity is governance-declared"
    },
    "verdict_record_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "verdict-record.schema.json instance"
    }
  },
  "additionalProperties": false
}
