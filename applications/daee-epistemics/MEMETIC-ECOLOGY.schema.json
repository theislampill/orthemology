{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Metaorthemic ecology Gamma^mu (R7C, Decision 0028)",
  "description": "A time-indexed typed graph of actors, institutions, artifacts, represented standards, metaortheme types, and episodes, with typed/versioned/provenanced edges. Not a vocabulary list: identity, timestamps, provenance, status, and lineage make transmission, copying, mutation, and false convergence distinguishable. Establishes no epistemic warrant from degree/count.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "t", "nodes", "edges", "tawatur_analyses"],
  "properties": {
    "schema": {"const": "orthemology-memetic-ecology-v1"},
    "t": {"type": "string", "description": "the time index of this snapshot"},
    "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}},
    "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}},
    "tawatur_analyses": {"type": "array", "items": {"$ref": "#/$defs/tawatur"}},
    "non_claims": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "node_type", "label", "provenance", "status"],
      "properties": {
        "id": {"type": "string"},
        "version": {"type": "string"},
        "node_type": {"enum": ["actor", "institution", "artifact", "represented-standard", "metaortheme-type", "episode"]},
        "label": {"type": "string"},
        "timestamp": {"type": "string"},
        "provenance": {"type": "string"},
        "status": {"enum": ["current", "superseded", "contested", "retired"]}
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "edge_type", "source", "target", "provenance", "status"],
      "properties": {
        "id": {"type": "string"},
        "edge_type": {"enum": ["transmission", "copying-dependence", "citation", "endorsement", "application", "mutation", "reinforcement", "rebuttal", "replacement", "supersession"]},
        "source": {"type": "string"},
        "target": {"type": "string"},
        "timestamp": {"type": "string"},
        "provenance": {"type": "string"},
        "status": {"enum": ["current", "superseded", "contested", "retired"]},
        "mutation_identity": {"enum": ["same-standard-new-token", "new-version-same-standard", "mutation-preserving-function", "new-governing-type"], "description": "for mutation edges: the identity relation (ablation-based, not wording similarity)"},
        "note": {"type": "string"}
      }
    },
    "tawatur": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "apparent_witnesses", "origin_analysis", "warrant_conclusion"],
      "properties": {
        "claim_id": {"type": "string"},
        "apparent_witnesses": {"type": "integer", "minimum": 1},
        "origin_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["independent_routes", "common_source", "copying_dependence", "mutation_lineage", "qualitative_indicants"],
          "properties": {
            "independent_routes": {"type": "integer", "minimum": 0},
            "common_source": {"type": "boolean"},
            "copying_dependence": {"type": "boolean"},
            "mutation_lineage": {"type": "boolean"},
            "qualitative_indicants": {"type": "string"}
          }
        },
        "warrant_conclusion": {"enum": ["tawatur-like-independence", "false-tawatur-common-source", "false-tawatur-copying", "underdetermined-needs-more-origin-analysis"]},
        "non_claims": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
